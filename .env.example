# PostgreSQL connection string used by the app at runtime.
# On Vercel with Neon this is the POOLED connection (Neon's integration sets it
# automatically). Local dev example below.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timetracker?schema=public"

# Direct (non-pooled) connection, used only by `prisma migrate deploy` at build time.
# Migrations must NOT run through a pooler (pgbouncer). On Vercel + Neon this is set
# automatically as DATABASE_URL_UNPOOLED. Locally, set it to the same value as
# DATABASE_URL (a direct connection).
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/timetracker?schema=public"

# REQUIRED in production. A long random string used to sign session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# SMTP settings for sending OTP emails.
# REQUIRED in production so users actually receive their code.
# If SMTP_HOST is unset (local dev only), codes are printed to the server console instead.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SurePath Time Tracker <no-reply@surepathvaluation.ca>"

# Comma-separated list of allowed email domains.
ALLOWED_EMAIL_DOMAINS="surepathvaluation.ca"

# Secret token that protects the /api/health diagnostics endpoint. Without it set,
# /api/health returns 404. To use it, set a long random value and call
# /api/health?token=YOUR_TOKEN (or send an x-health-token header).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
HEALTH_CHECK_TOKEN=""
