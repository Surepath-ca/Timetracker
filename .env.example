# PostgreSQL connection string.
# Local dev example: postgresql://postgres:postgres@localhost:5432/timetracker?schema=public
# On Vercel, use a hosted Postgres (Vercel Postgres, Neon, or Supabase).
# Use the DIRECT (non-pooled) connection string here — the build step runs
# `prisma migrate deploy`, which needs a direct connection. A direct connection is
# fine for this low-traffic internal app.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timetracker?schema=public"

# REQUIRED in production. A long random string used to sign session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# SMTP settings for sending OTP emails.
# REQUIRED in production so users actually receive their code.
# If SMTP_HOST is unset (local dev only), codes are printed to the server console instead.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SurePath Time Tracker <no-reply@surepathvaluation.ca>"

# Comma-separated list of allowed email domains.
ALLOWED_EMAIL_DOMAINS="surepathvaluation.ca"
